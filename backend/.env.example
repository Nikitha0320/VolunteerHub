# Spring Boot backend environment variables
# Replace all CHANGE_ME values before running.
# Example URL format:
# jdbc:mysql://your-hostname:3306/your_db_name?ssl-mode=REQUIRED
SPRING_DATASOURCE_URL=CHANGE_ME
SPRING_DATASOURCE_USERNAME=CHANGE_ME
SPRING_DATASOURCE_PASSWORD=CHANGE_ME
APP_JWT_SECRET=CHANGE_ME
APP_JWT_EXPIRATION_MS=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
